-- КЕЙС №24: СТЕ-МАГИСТРАЛИ И СКВОЗНАЯ СШИВКА ДВОЙНОГО LEFT JOIN ДЛЯ СВЕРКИ БАЛАНСОВ
-- Бизнес-задача: Сформировать аналитический реестр верификации балансов. Сконсолидировать данные из справочника клиентов, лога платежей и лога начисленных бонусов. Изолировать контрагентов, у которых сумма фактических оплат строго равна сумме начисленных бонусов, обеспечив сохранение всей клиентской базы на этапе сопряжения.

WITH compiled_balances AS (
    -- ВЫЧИСЛИТЕЛЬНЫЙ ЦЕХ (CTE): Консолидация данных и нормализация качества (Data Quality)
    SELECT 
        t1.client_id AS g1, 
        TRIM(LOWER(t1.client_name)) AS g2, 
        COALESCE(t2.pay_amount, 0) AS g3, 
        COALESCE(t3.bonus_amount, 0) AS g4 
    FROM clients AS t1 -- [Исправление] Сбриты лишняя запятая и Cross-join зазор моторики
    
    -- ПЕРВЫЙ ЛЕВЫЙ МОСТ: Пришиваем лог платежей к справочнику клиентов
    LEFT JOIN client_payments AS t2 
        ON t1.client_id = t2.client_id 
        
    -- ВТОРОЙ ЛЕВЫЙ МОСТ: Пришиваем лог бонусов жестко к справочнику-донору t1
    -- [Исправление] Исключена аннигиляция "молчунов" за счет перепривязки сопряжения с t2.client_id на базовый ключ t1.client_id
    LEFT JOIN client_bonuses AS t3 
        ON t1.client_id = t3.client_id 
)

-- ГЛАВНЫЙ ВНЕШНИЙ КОНТУР: Формирование витрины совпадения финансовых метрик
SELECT 
    compiled_balances.g2 AS "Клиенты_чей_платеж_равен_сумме_бонусов" -- [Исправление текста] Устранено дублирование слова
FROM compiled_balances -- [Исправление] Исключен ломающий логику и кодировки алиас FSTT

-- ХИРУРГИЧЕСКОЕ СИТО WHERE: Выделение транзакций с абсолютным равенством оплат и бонусов (g3 = g4)
WHERE compiled_balances.g3 = compiled_balances.g4 

-- СОРТИРОВКА ВИТРИНЫ: Алфавитное упорядочивание реестра по нормализованным именам клиентов
ORDER BY compiled_balances.g2 ASC;
